# Security & API
API_KEY=dev-secret-key-123
API_KEYS=[]
ALLOWED_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]
HMAC_ENABLED=false
HMAC_SECRET=
AUDIT_LOG_ENABLED=true

# Model Configuration
MODEL_PATH=models/malicious_content_detector_calibrated.pkl
CONFIG_PATH=models/malicious_content_detector_config.pkl
MODEL_VERSION=v1.0.0
# WARNING: Default threshold for development only.
# This value (0.589) is F1-optimized for the MPDD demo dataset (via PR curve analysis).
# Production deployments should re-evaluate thresholds based on your specific dataset.
DECISION_THRESHOLD=0.589

# Rate Limiting & Performance
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=60
MAX_TEXT_LENGTH=10000
MAX_BATCH_ITEMS=1000
MAX_CSV_BYTES=10485760

# Circuit Breaker & Resilience
BREAKER_ENABLED=true
BREAKER_FAILURE_THRESHOLD=5
BREAKER_COOLDOWN_SECONDS=30
