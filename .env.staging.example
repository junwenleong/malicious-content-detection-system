# Staging Environment Configuration
# Copy to .env for staging deployment

# Security & API
API_KEY=staging-secret-key-change-me-in-production
API_KEYS=[]
ALLOWED_ORIGINS=["https://staging.your-domain.com"]
HMAC_ENABLED=true
HMAC_SECRET=staging-hmac-secret-minimum-32-characters-required-change-me
AUDIT_LOG_ENABLED=true

# Model Configuration
MODEL_PATH=models/malicious_content_detector_calibrated.pkl
CONFIG_PATH=models/malicious_content_detector_config.pkl
MODEL_VERSION=v1.0.0
# Threshold should be re-evaluated for your specific dataset
DECISION_THRESHOLD=0.589

# Rate Limiting & Performance
RATE_LIMIT_MAX=500
RATE_LIMIT_WINDOW=60
MAX_TEXT_LENGTH=10000
MAX_BATCH_ITEMS=1000
MAX_CSV_BYTES=10485760

# Circuit Breaker & Resilience
BREAKER_ENABLED=true
BREAKER_FAILURE_THRESHOLD=5
BREAKER_COOLDOWN_SECONDS=30

# Workers (auto-detect if not set)
WORKERS=
