{
  "enabled": true,
  "name": "Run Fast Tests on Save",
  "description": "Runs the fast unit test suite whenever a test file is saved, giving immediate feedback on test results",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "tests/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "export PYTHONPATH=. && python -m pytest tests/ -q --tb=short -m \"not slow and not integration\" --timeout=10",
    "timeout": 60
  }
}
