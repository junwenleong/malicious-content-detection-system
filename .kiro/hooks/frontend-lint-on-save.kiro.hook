{
  "enabled": true,
  "name": "Frontend Lint on Save",
  "description": "Runs ESLint and TypeScript type check on saved frontend files",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "frontend/src/**/*.ts",
      "frontend/src/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx eslint $FILE && npx tsc --noEmit",
    "timeout": 30
  }
}
