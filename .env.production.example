# Security & API
API_KEY=replace_with_strong_key_in_production
ALLOWED_ORIGINS=["https://your-frontend.example.com"]
FASTUI_ENABLED=false

# HMAC Signature Verification
HMAC_ENABLED=true
HMAC_SECRET=replace_with_minimum_32_char_secret_here

# Audit Logging
AUDIT_LOG_ENABLED=true

# Model Configuration
MODEL_PATH=/app/models/malicious_content_detector_calibrated.pkl
CONFIG_PATH=/app/models/malicious_content_detector_config.pkl
MODEL_VERSION=v1.0.0
DECISION_THRESHOLD=0.54

# Rate Limiting & Performance
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60
MAX_TEXT_LENGTH=10000
MAX_BATCH_ITEMS=1000
MAX_CSV_BYTES=10485760

# Circuit Breaker & Resilience
BREAKER_ENABLED=true
BREAKER_FAILURE_THRESHOLD=5
BREAKER_COOLDOWN_SECONDS=30
